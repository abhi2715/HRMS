# ============================================================
# Autonomous HR Copilot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values

# ── Database ─────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hrms
POSTGRES_USER=hrms_user
POSTGRES_PASSWORD=hrms_secure_password_2024

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password_2024

# ── Qdrant ───────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Backend ──────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
ENVIRONMENT=development
DEBUG=true

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=HR Copilot

# ── LLM Configuration ───────────────────────────────────────
# Primary: Ollama (Llama 3.3 70B)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.3:70b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Secondary: OpenAI (Fallback)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Active LLM provider: ollama or openai
LLM_PROVIDER=openai

# ── Email ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@hrcopilot.ai

# ── n8n ──────────────────────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=n8n_secure_password

# ── File Storage ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
